APP_ENV=local
LOG_LEVEL=INFO
MODEL_PROVIDER=mock

# LLM routing
ENABLE_REAL_LLM=false
LLM_DEFAULT_PROVIDER=mock
# JSON map of role → provider config. Example with both Part 2 classifier and Part 3 generator:
# LLM_ROLE_CONFIG_JSON={"doubt_solver_classifier": {"provider": "azure_openai", "model_label": "classifier-model", "deployment": "YOUR_AZURE_CLASSIFIER_DEPLOYMENT", "temperature": 0, "max_tokens": 500, "supports_streaming": false}, "doubt_solver_generator": {"provider": "azure_openai", "model_label": "generator-model", "deployment": "YOUR_AZURE_GENERATOR_DEPLOYMENT", "temperature": 0.2, "max_tokens": 1200, "supports_streaming": false}}
LLM_ROLE_CONFIG_JSON={}

# Azure OpenAI (required when provider=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=

# OpenAI native (required when provider=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Bedrock Knowledge Base retrieval (Part 7)
# Set ENABLE_KB_RETRIEVAL=true to activate.  BEDROCK_KB_ID is required when enabled.
ENABLE_KB_RETRIEVAL=false
BEDROCK_KB_ID=
# BEDROCK_KB_REGION defaults to AWS_REGION if not set (boto3 default chain applies).
BEDROCK_KB_REGION=
BEDROCK_KB_MAX_RESULTS=5
# Optional: filter results below this similarity score threshold (e.g. 0.7).
# Leave empty to return all results regardless of score.
BEDROCK_KB_MIN_SCORE=

# DynamoDB record fetch (Part 8)
# Set ENABLE_DYNAMODB_FETCH=true to activate.  Table names are required when enabled.
ENABLE_DYNAMODB_FETCH=false
DYNAMODB_QUESTION_TABLE=
DYNAMODB_PATTERN_TABLE=
# Optional: default GSI/LSI name for index-based queries.
DYNAMODB_DEFAULT_INDEX=
# Optional: AWS region for DynamoDB client. Defaults to AWS_REGION or boto3 chain.
DYNAMODB_REGION=

# Context builder (Part 9)
# Hard cap on the context string (chars) passed to the answer generator.
# Reduce this value to lower prompt token cost; increase for richer context.
DOUBT_SOLVER_MAX_CONTEXT_CHARS=6000

# AWS credentials (required for ENABLE_KB_RETRIEVAL=true or ENABLE_DYNAMODB_FETCH=true)
#
# boto3 uses its standard credential chain:
#   1. Environment vars below
#   2. ~/.aws/credentials  (shared credentials file)
#   3. ~/.aws/config       (profile config)
#   4. IAM instance role   (EC2, ECS, Lambda)
#
# For local dev: export these in your shell or fill them in here.
# WARNING: NEVER commit real AWS keys. This file is gitignored.
#
AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
#
# If using AWS SSO or a named profile, set AWS_PROFILE instead:
# AWS_PROFILE=
